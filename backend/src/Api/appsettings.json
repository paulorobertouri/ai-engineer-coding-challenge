{
  "OpenAI": {
    "ApiKey": "",
    "EnableTools": true,
    "ChatModel": "gpt-4o-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "Challenge": {
    "SourceDocumentPath": "../../../../knowledge-base/Grocery_Store_SOP.md",
    "VectorStorePath": "Data/vector-store.json"
  },
  "VectorStore": {
    "Provider": "json"
  },
  "Retrieval": {
    "TopK": 3,
    "MinSimilarityScore": 0.3,
    "EnableQueryRewriting": true,
    "EnableReranking": true,
    "RerankCandidateMultiplier": 3
  },
  "Guardrails": {
    "EnableRuleBasedGuardrails": true,
    "Categories": [
      {
        "Name": "medical",
        "EscalationMessage": "I cannot provide medical guidance. Please contact your manager or approved healthcare and safety channel.",
        "Keywords": ["injury", "bleeding", "medication", "allergic", "medical"]
      },
      {
        "Name": "legal",
        "EscalationMessage": "I cannot provide legal advice. Please escalate this to your manager or legal team.",
        "Keywords": ["lawsuit", "legal advice", "sue", "attorney", "court"]
      },
      {
        "Name": "emergency",
        "EscalationMessage": "For emergencies, follow your emergency SOP and contact emergency services or your manager immediately.",
        "Keywords": ["fire", "threat", "weapon", "emergency", "evacuate"]
      },
      {
        "Name": "hr",
        "EscalationMessage": "This topic should be handled through your manager or HR channel.",
        "Keywords": ["harassment", "payroll", "termination", "disciplinary", "complaint about manager"]
      }
    ]
  },
  "RateLimiting": {
    "Chat": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Ingest": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Upload": {
    "MaxUploadBytes": 10485760
  },
  "Timeouts": {
    "ChatSeconds": 30,
    "IngestSeconds": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
