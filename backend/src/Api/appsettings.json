{
  "OpenAI": {
    "ApiKey": "",
    "EnableTools": true,
    "ChatModel": "gpt-4o-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "Challenge": {
    "SourceDocumentPath": "../../../../knowledge-base/Grocery_Store_SOP.md",
    "VectorStorePath": "Data/vector-store.json"
  },
  "VectorStore": {
    "Provider": "json"
  },
  "Retrieval": {
    "TopK": 3,
    "MinSimilarityScore": 0.3
  },
  "RateLimiting": {
    "Chat": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Ingest": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Upload": {
    "MaxUploadBytes": 10485760
  },
  "Timeouts": {
    "ChatSeconds": 30,
    "IngestSeconds": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
