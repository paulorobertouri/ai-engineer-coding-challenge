{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:backend",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/backend/src/Api/Api.csproj"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test:backend",
      "command": "dotnet",
      "type": "process",
      "args": ["test", "${workspaceFolder}/backend/src/Api.Tests/Api.Tests.csproj"],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "install:frontend",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "test:frontend",
      "type": "shell",
      "command": "npm test",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    }
  ]
}
